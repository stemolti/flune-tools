{
  "name": "@stemolti/flune",
  "version": "0.2.0",
  "description": "Plugin manager and local MCP proxy — an OpenAI-compatible endpoint that gives any LLM client MCP tool-calling via OpenRouter",
  "license": "MIT",
  "author": {
    "name": "Tete Stefano Agbodan"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stemolti/flune-tools",
    "directory": "flune"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "flune": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openrouter",
    "openai-compatible",
    "proxy",
    "cli",
    "plugins"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "fastify": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
